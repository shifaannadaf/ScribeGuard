DATABASE_URL=postgresql://scribeguard:scribeguard@localhost:5432/scribeguard

# ── AI provider ───────────────────────────────────────────────────────────
# "openai" → Whisper + GPT (paid)
# "local"  → faster-whisper + Ollama llama3.2 (free, runs locally)
SERVICE_PROVIDER=openai

# ── OpenAI (only used when SERVICE_PROVIDER=openai) ──────────────────────
OPENAI_API_KEY==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
WHISPER_MODEL=whisper-1
SOAP_MODEL=gpt-4o-mini
MEDICATION_MODEL=gpt-4o-mini

# ── Local provider (only used when SERVICE_PROVIDER=local) ───────────────
# faster-whisper: tiny | base | small | medium | large-v3
LOCAL_WHISPER_MODEL=base
LOCAL_WHISPER_DEVICE=cpu
LOCAL_WHISPER_COMPUTE_TYPE=int8

# Ollama (requires `ollama serve` + `ollama pull llama3.2` once)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=120
